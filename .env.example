# ── Anthropic API ──────────────────────────────────────────────────────────────
# https://console.anthropic.com → API Keys 에서 발급
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ── 네이버 계정 (자동 로그인용) ────────────────────────────────────────────────
# 2FA / 캡차가 없는 일반 계정만 동작. 로그인 성공 시 data/auth_state.json 에 세션 저장.
NAVER_ID=your_naver_id
NAVER_PW=your_naver_password

# ── 블로그 ID ───────────────────────────────────────────────────────────────────
# Phase A 크롤러: 이 블로그에서 스타일을 학습합니다. (예: bbtn96)
# Phase B 포스팅: 이 블로그에 글을 올립니다. (예: punx2-)
# 두 단계를 순서대로 사용하는 경우 Phase A 완료 후 내 블로그 ID로 바꾸세요.
BLOG_ID=bbtn96

# ── 카테고리 이름 ────────────────────────────────────────────────────────────────
# 블로그에 표시된 카테고리명 그대로 입력 (공백, 슬래시 포함).
# Phase A 크롤러: 수집 대상 카테고리 / Phase B 포스팅: 카테고리 자동 선택 시도.
CATEGORY_NAME=맛집/카페

# ── 수집할 글 개수 (Phase A 크롤러) ──────────────────────────────────────────────
NUM_POSTS=20
